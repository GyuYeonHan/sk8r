DATABASE_URL="file:./dev.db"
# 32-byte key in base64 (required)
# Example generation:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=""

# Keycloak OIDC (required)
KEYCLOAK_ISSUER_URL="https://keycloak.example.com/realms/<realm>"
KEYCLOAK_CLIENT_ID="sk8r"
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_ADMIN_ROLE="admin"

# Auth session cookie encryption (optional; falls back to APP_ENCRYPTION_KEY)
AUTH_SESSION_SECRET=""
AUTH_SESSION_MAX_AGE_SECONDS="28800"

# Optional base URL for callback/logout URL generation
APP_BASE_URL="http://localhost:5173"

# Optional metrics endpoint
PROMETHEUS_URL="http://kube-prometheus-stack-prometheus.monitoring:9090"
